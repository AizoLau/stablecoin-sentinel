# Arc Testnet (Chain ID 5042002, gas denominated in USDC)
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002
ARC_RPC_URL_ALCHEMY=
ARC_RPC_URL_QUICKNODE=
ARC_EXPLORER_URL=https://explorer.testnet.arc.network

# Google Gemini (agent reasoning)
GEMINI_API_KEY=
GEMINI_MODEL_PRO=gemini-2.5-pro
GEMINI_MODEL_FLASH=gemini-2.5-flash

# DeBank Cloud (cross-chain address profiling)
DEBANK_ACCESSKEY=
DEBANK_BASE_URL=https://pro-openapi.debank.com

# Circle Wallets Developer-Controlled API
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
CIRCLE_SENTINEL_WALLET_ID=
CIRCLE_SENTINEL_WALLET_ADDRESS=

# Test wallets (testnet only; generate with `cast wallet new -n 5`)
DEPLOYER_PRIVATE_KEY=
DEPLOYER_ADDRESS=
SENTINEL_PRIVATE_KEY=
SENTINEL_ADDRESS=
DEMO_ALICE_PRIVATE_KEY=
DEMO_ALICE_ADDRESS=
DEMO_BOB_PRIVATE_KEY=
DEMO_BOB_ADDRESS=
DEMO_RECOVERY_PRIVATE_KEY=
DEMO_RECOVERY_ADDRESS=

# Deployed contracts (filled after deployment)
MOCK_USDC_ADDR=

# Backend
LOG_LEVEL=INFO
SQLITE_PATH=./audit.db
SSE_HEARTBEAT_SECONDS=15
